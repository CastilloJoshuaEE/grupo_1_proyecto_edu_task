<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- MENSAJE -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#E65100"
        android:hint="Mensaje del recordatorio">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMensajeRecordatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:inputType="textMultiLine"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- FECHA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fecha"
        android:textStyle="bold"
        android:layout_marginTop="14dp"/>

    <TextView
        android:id="@+id/tvFechaRecordatorioForm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Toque para seleccionar fecha"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/borde_campo"
        android:textColor="@android:color/darker_gray"/>

    <!-- HORA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hora"
        android:textStyle="bold"
        android:layout_marginTop="14dp"/>

    <TextView
        android:id="@+id/tvHoraRecordatorioForm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Toque para seleccionar hora"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/borde_campo"
        android:textColor="@android:color/darker_gray"/>

</LinearLayout>
